FROM rust:1.93-slim AS shell-builder

WORKDIR /build
COPY shell/ /build/shell/
COPY Cargo.toml /build/
RUN cargo build --release -p caloron-shell && \
    cp target/release/caloron-shell /usr/local/bin/

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git bubblewrap curl && rm -rf /var/lib/apt/lists/*

# Install caloron-shell
COPY --from=shell-builder /usr/local/bin/caloron-shell /usr/local/bin/caloron-shell

# Install Claude Code (or use API key mode)
RUN curl -fsSL https://claude.ai/install.sh | sh 2>/dev/null || true

# Copy sandbox script
COPY scripts/sandbox-agent.sh /usr/local/bin/sandbox-agent

WORKDIR /workspace

ENV CALORON_SHELL_PORT=7710

EXPOSE 7710

ENTRYPOINT ["caloron-shell"]

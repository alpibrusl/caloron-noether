{
  "description": "Caloron sprint tick — poll GitHub, advance DAG, supervise agents",
  "version": "0.1.0",
  "root": {
    "op": "Sequential",
    "stages": [
      {
        "op": "Parallel",
        "branches": {
          "dag_state": {
            "op": "Stage", "id": "TODO:kv_get",
            "_comment": "Load DagState from kv: caloron:{sprint_id}:state"
          },
          "last_poll": {
            "op": "Stage", "id": "TODO:kv_get",
            "_comment": "Load last_poll timestamp from kv: caloron:{sprint_id}:last_poll"
          },
          "agents": {
            "op": "Stage", "id": "TODO:kv_get",
            "_comment": "Load agents heartbeat map from KV"
          }
        }
      },
      {
        "op": "Stage", "id": "TODO:github_poll_events",
        "_comment": "Fetch GitHub events since last_poll"
      },
      {
        "op": "Stage", "id": "TODO:kv_set",
        "_comment": "Save polled_at as new last_poll"
      },
      {
        "op": "Stage", "id": "TODO:dag_evaluate",
        "_comment": "Advance task states from events, produce actions list"
      },
      {
        "op": "Stage", "id": "TODO:kv_set",
        "_comment": "Persist updated DagState to KV"
      },
      {
        "op": "Parallel",
        "branches": {
          "health": {
            "op": "Sequential",
            "stages": [
              {
                "op": "Stage", "id": "TODO:check_agent_health",
                "_comment": "Classify each agent's health status"
              },
              {
                "op": "Stage", "id": "TODO:decide_intervention",
                "_comment": "Determine action for each unhealthy agent"
              }
            ]
          },
          "dag_status": {
            "op": "Stage", "id": "TODO:dag_is_complete",
            "_comment": "Check if sprint is finished"
          }
        }
      },
      {
        "op": "Stage", "id": "TODO:execute_actions",
        "_comment": "Dispatch actions: spawn agents, post comments, merge PRs, escalate. Calls caloron-shell /spawn endpoint."
      }
    ]
  }
}

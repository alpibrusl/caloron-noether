[192.752083, "o", "  \"\"\"Finds the cheapest contiguous charging window for a truck given 24 hourly electricity prices.\"\"\"\r\n  \r\n  HOURS_IN_DAY = 24\r\n  \r\n  \r\n  def find_cheapest_window(prices: list[float], window_size: int = 4) -> dict:\r\n      if len(prices) != HOURS_IN_DAY:\r\n          raise ValueError(f\"prices must have exactly {HOURS_IN_DAY} entries, got {len(prices)}\")\r\n      if window_size < 1 or window_size > HOURS_IN_DAY:\r\n          raise ValueError(f\"window_size must be between 1 and {HOURS_IN_DAY}, got {window_size}\")\r\n  \r\n      best_start = 0\r\n      best_cost = sum(prices[:window_size])\r\n      current_cost = best_cost\r\n  \r\n      for start in range(1, HOURS_IN_DAY - window_size + 1):\r\n          current_cost += prices[start + window_size - 1] - prices[start - 1]\r\n          if current_cost < best_cost:\r\n              best_cost = current_cost\r\n              best_start = start\r\n"]
[192.752147, "o", "  ... (53 more lines)\r\n\r\n  \u001b[32m✓\u001b[0m src/charging_optimizer.py: 73 lines, 3 functions\r\n"]

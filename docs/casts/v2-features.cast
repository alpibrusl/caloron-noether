[29.402077, "o", "\r\n\u001b[1m\u001b[32m  Pipeline: Goal → PO → Roles → HR Agent → Skills → Template → Config → Agent\u001b[0m\r\n\r\n  \u001b[1m18 roles\u001b[0m across 7 departments\r\n  \u001b[1m20 skills\u001b[0m with full dependency chains (nix + pip + npm + setup)\r\n  \u001b[1m5 templates\u001b[0m (YAML, user-extensible, LLM-generated)\r\n"]
[29.402135, "o", "  \u001b[1m6 frameworks\u001b[0m (claude-code, cursor, gemini, codex, open-code, aider)\r\n  \u001b[1mAuto-deploy\u001b[0m after sprint (detect → test → build → preview)\r\n\r\n  \u001b[2mOpen source: github.com/alpibrusl/caloron-noether\u001b[0m\r\n\r\n"]

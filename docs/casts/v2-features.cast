[24.957357, "o", "  claude-code:\r\n    .mcp.json\r\n    CLAUDE.md\r\n    requirements-skills.txt\r\n\r\n"]
[25.33114, "o", "  cursor-cli:\r\n    .cursor/mcp.json\r\n    .cursorrules\r\n    requirements-skills.txt\r\n\r\n"]

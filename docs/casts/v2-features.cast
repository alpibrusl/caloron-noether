[10.694068, "o", "  browser-automation:\r\n    nix: ['python311', 'chromium']\r\n    pip: ['playwright']\r\n    setup: ['playwright install chromium']\r\n\r\n  rest-api-development:\r\n    nix: ['python311']\r\n    pip: ['fastapi', 'uvicorn', 'pydantic', 'httpx']\r\n\r\n  sql-database:\r\n    nix: ['postgresql_16']\r\n    pip: ['sqlalchemy', 'asyncpg', 'psycopg2-binary']\r\n    mcp: postgresql://...\r\n\r\n  data-analysis-pandas:\r\n    nix: ['python311']\r\n    pip: ['pandas', 'numpy']\r\n\r\n"]

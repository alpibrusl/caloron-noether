[4.713825, "o", "\r\n  [ARCHITECTURE]\r\n    software-architect        Software Architect        model=strong     [python-development, rest-api-development, web-search +2]\r\n    tech-lead                 Tech Lead                 model=strong     [python-development, rest-api-development, git-operations +1]\r\n\r\n  [DATA]\r\n    data-analyst              Data Analyst              model=balanced   [python-development, data-analysis-pandas, sql-database +1]\r\n    data-scientist            Data Scientist            model=strong     [python-development, data-analysis-pandas, sql-database +3]\r\n\r\n  [DOCUMENTATION]\r\n    technical-writer          Technical Writer          model=fast       [python-development, web-search, git-operations +1]\r\n\r\n  [ENGINEERING]\r\n    backend-engineer          Backend Engineer          model=balanced   [python-development, rest-api-development, sql-database +3]\r\n    data-engineer             Data Engineer             model=balanced   [python-development, sql-database, data-analysis-pandas +4]\r\n    frontend-engineer         Frontend Engineer         model=balanced   [typescript-development, jest-testing, git-operations +1]\r\n    fullstack-engineer        Fullstack Engineer        model=balanced   [python-development, typescript-development, rest-api-development +5]\r\n    ml-engineer               ML Engineer               model=strong     [python-development, data-analysis-pandas, pytest-testing +2]\r\n    mobile-engineer           Mobile Engineer           model=balanced   [typescript-development, jest-testing, git-operations +1]\r\n\r\n  [PRODUCT]\r\n    product-manager           Product Manager           model=strong     [web-search, git-operations, github-pr-management]\r\n    ux-designer               UX Designer               model=balanced   [typescript-development, browser-automation, web-search +2]\r\n    ux-researcher             UX Researcher             model=balanced   [web-search, browser-automation, data-analysis-pandas +1]\r\n\r\n"]
